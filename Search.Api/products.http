@baseUrl = http://localhost:5080
@contentType = application/json

### Ricerca: price >= 10 AND tags ⊇ {sale|novità}, ordinati per prezzo desc
POST {{baseUrl}}/products/search
Content-Type: {{contentType}}

{
  "filter": {
    "and": [
      { "field": "brandName", "op": "eq", "value": "Lorenzo" },
      { "field": "price", "op": "gte", "value": 10 },
      { "field": "tags", "op": "containsAny", "values": ["sale", "novità"] }
    ]
  },
  "projection": ["name", "brandName", "price", "tags", "priceAmount"],
  "sort": [{ "field": "price", "direction": "Descending" }],
  "page": { "number": 1, "size": 20 }
}

### Ricerca: price >= 10 AND tags ⊇ {sale|novità}, ordinati per prezzo desc
POST {{baseUrl}}/products/search
Content-Type: {{contentType}}

{
  "projection": ["name", "price", "tags"],
  "page": { "number": 1, "size": 20 }
}

### Ricerca: filtro annidato con OR e NOT
POST {{baseUrl}}/products/search
Content-Type: {{contentType}}

{
  "filter": {
    "and": [
      { "field": "price", "op": "gte", "value": 10 },
      { "or": [
        { "field": "tags", "op": "containsAny", "values": ["sale"] },
        { "not": { "field": "status", "op": "eq", "value": "Discontinued" } }
      ] }
    ]
  },
  "projection": ["name", "price", "status", "tags"]
}

### Ricerca: contains su name
POST {{baseUrl}}/products/search
Content-Type: {{contentType}}

{
  "filter": { "field": "name", "op": "contains", "value": "Widget" },
  "projection": ["name", "price"]
}